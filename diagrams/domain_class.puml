@startuml domain_class
' ============================================================
' HRS 概念クラス図（演習1 / ドメイン分析）日本語版
' Issue: [Domain] 概念クラス図を作成する
'
' 方針:
'   - ホテル業務に存在する概念だけを置く（実装クラスは入れない）
'   - 状態は「属性の型」として列挙を指す（点線の依存は描かない）
'   - 多重度・ロール名・集約を明示する
' ============================================================

skinparam classAttributeIconSize 0
hide circle

class 顧客 {
  顧客ID
  氏名
  電話番号
  メールアドレス
}

class フロント係 {
  係員ID
  氏名
}

class ホテル {
  ホテルID
  ホテル名
}

class 部屋 {
  部屋番号
  状態 : 部屋状態
}

class 部屋種別 {
  種別ID
  種別名
  定員
  一泊料金
}

class 予約 {
  予約番号
  チェックイン日
  チェックアウト日
  状態 : 予約状態
  作成日時
}

class 宿泊 {
  宿泊ID
  実チェックイン日時
  実チェックアウト日時
}

class 請求 {
  請求番号
  合計金額
  発行日時
}

class 支払い {
  支払番号
  金額
  支払方法
  支払日時
}

' 状態が取りうる値の一覧（型の定義）。属性側から型として参照するため、点線は描かない
enum 予約状態 {
  RESERVED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

enum 部屋状態 {
  AVAILABLE
  OCCUPIED
  OUT_OF_SERVICE
}

' ============================================================
' 関係と多重度
' ============================================================
ホテル      "1"    o-- "*"    部屋        : 所有
部屋種別    "1"    --  "*"    部屋
顧客        "1"    --  "*"    予約
予約        "*"    --  "1"    部屋種別
予約        "0..1" --  "0..1" 部屋        : 割当部屋
予約        "1"    --  "0..1" 宿泊
宿泊        "1"    --  "0..1" 請求
請求        "1"    --  "0..1" 支払い
フロント係  "*"    --  "*"    宿泊        : 担当

@enduml
